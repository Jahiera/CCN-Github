  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Hey newbie,\n\nThis dream comes from Jonathan\u2019s adulthood, where
    his fears start to feel more physical and immediate. It takes place on a ship
    that is slowly sinking, with water rising as time passes. The environment is
    unstable, and hesitation can cost you.\n\nHelp Jonathan move quickly and find
    a way out before the ship goes under. There is a time limit, and the rising water
    adds constant pressure. This dream reflects Jonathan\u2019s feeling of losing
    control and being overwhelmed by responsibility, so staying focused and pushing
    forward is key.\n\nYou can do this!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 14332c434199d405389a686126a1f137, type: 2}
