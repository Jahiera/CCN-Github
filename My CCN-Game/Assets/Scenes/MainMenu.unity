    m_PersistentCalls:
      m_Calls: []
  m_text: "Hey newbie,\n\nYou are still assigned to Jonathan. This dream comes from
    his teenage years and focuses on feelings of embarrassment and exposure. The
    environment is built to make being seen feel uncomfortable, so moving carefully
    is important. The figures you encounter represent people he fears being judged
    by rather than direct threats.\n\nIf you are spotted, Jonathan\u2019s embarrassment
    will start to rise. Your task is to move through the area without drawing attention
    and find a safe place to hide. The goal here is to help him escape situations
    where he feels exposed and overwhelmed."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 14332c434199d405389a686126a1f137, type: 2}
  m_sharedMaterial: {fileID: -8389354278039786611, guid: 14332c434199d405389a686126a1f137, type: 2}
